<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive-icon foreground: dark crop marks + AI sparkle + faint overlap square.
     Drawn in the source 130-unit space; every mark stays inside the inscribed
     safe circle, so no launcher mask (circle/squircle/rounded-square) clips it. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="130"
    android:viewportHeight="130">
    <!-- faint offset square (the "second crop" hint) -->
    <path
        android:fillColor="#2C2C2A"
        android:fillAlpha="0.12"
        android:pathData="M38,38 h54 v54 h-54 z" />
    <!-- crop marks -->
    <path
        android:strokeColor="#2C2C2A"
        android:strokeWidth="7"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M38,20 V92 H110" />
    <path
        android:strokeColor="#2C2C2A"
        android:strokeWidth="7"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M20,38 H92 V110" />
    <!-- four-point AI sparkle -->
    <path
        android:fillColor="#2C2C2A"
        android:pathData="M65,48 C65,60.75 69.25,65 82,65 C69.25,65 65,69.25 65,82 C65,69.25 60.75,65 48,65 C60.75,65 65,60.75 65,48 Z" />
</vector>
